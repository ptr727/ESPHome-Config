# Replace substitutions and rename to secrets.yaml

wifi_ssid: "ssid"
wifi_password: "password"
wifi_domain: ".local"

# Generate with: openssl rand -base64 32
api_encryption_key: "REPLACE_WITH_BASE64_32_BYTE_KEY"
ota_password: "password"

# Micro-Air EasyStart module BLE MACs, used by office-bluetooth-proxy.yaml.
# Discover your own with: uv run easystart/python/easystart_monitor.py --discover
easystart_hvac1_mac: "AA:BB:CC:DD:EE:01"
easystart_hvac2_mac: "AA:BB:CC:DD:EE:02"
